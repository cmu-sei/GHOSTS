# --- n8n Database ---
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme-n8n-db

# --- n8n Encryption ---
# CRITICAL: Once set, never change. Credentials become unreadable if this changes.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# --- n8n Owner Account ---
# The provisioner creates this account on first boot via the n8n REST API.
N8N_OWNER_EMAIL=ranger@admin.local
N8N_OWNER_FIRST_NAME=Ranger
N8N_OWNER_LAST_NAME=admin
# Password must meet n8n complexity requirements (8+ chars, uppercase, number, special char)
N8N_OWNER_PASSWORD=Ranger@@1!

# --- Timezone ---
GENERIC_TIMEZONE=UTC
