    {
      "parameters": {
        "jsCode": "// Get all incoming items\nconst items = $input.all();\n\n// Case 1: HTTP returned ONE item containing an array\nlet npcs;\nif (items.length === 1 && Array.isArray(items[0].json)) {\n  npcs = [...items[0].json];\n}\n// Case 2: Multiple items already split\nelse {\n  npcs = items.map(i => i.json);\n}\n\n// Fisher–Yates shuffle\nfor (let i = npcs.length - 1; i > 0; i--) {\n  const j = Math.floor(Math.random() * (i + 1));\n  [npcs[i], npcs[j]] = [npcs[j], npcs[i]];\n}\n\n// Select up to 10\nconst selected = npcs.slice(0, 10);\n\n// Return as n8n items\nreturn selected.map(npc => ({ json: npc }));\n"
      },
      "id": "424e6eb9-48c5-4953-bcc3-6879d939c35e",
