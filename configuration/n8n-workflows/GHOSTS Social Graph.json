    {
      "parameters": {
        "jsCode": "const topics = [\n  'cybersecurity','cloud computing','artificial intelligence',\n  'data science','devops','networking','programming',\n  'system administration','database management','security operations'\n];\n\n\nconst topic = topics[Math.floor(Math.random() * topics.length)];\n\nreturn {\n  json: {\n    npcId: $('Set Id').first().json.id,\n    fromNpcId: $('Select Random Targets').first().json.connectedNpcId,\n    toNpcId: $('Set Id').first().json.id,\n    topic,\n    step: Date.now(),\n    value: 1,\n    targetName: ''\n  }\n};\n"
      },
