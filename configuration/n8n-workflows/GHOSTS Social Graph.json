    {
      "parameters": {
        "jsCode": "const npcId = $('Split NPCs').item.json.id;\nconst allNpcs = $input.item.json;\n\n// Filter out self and take first 10\nconst connections = allNpcs\n  .filter(n => n.id !== npcId)\n  .slice(0, 10);\n\nreturn connections.map(conn => ({\n  json: {\n    npcId: npcId,\n    connectedNpcId: conn.id,\n    name: conn.name\n  }\n}));"
      },
      "id": "d1a1245d-4400-4e2b-88b9-dd821103bcf7",
      "name": "Prepare Initial Connections",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        464
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://host.docker.internal:5000/api/npcs/{{ $json.npcId }}/connections",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"connectedNpcId\": \"{{ $json.connectedNpcId }}\",\n  \"name\": \"{{ $json.name }}\",\n  \"distance\": \"\",\n  \"relationshipStatus\": 0.0\n}",
        "options": {}
      },
      "id": "5764fc82-03e2-4dff-9757-329cd7ac6f82",
      "name": "Create Connection via API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -448,
        464
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (!items || items.length === 0) {\n  return [];\n}\n\nlet npcConnections;\n\n// Case 1: HTTP returned ONE item containing an array\nif (items.length === 1 && Array.isArray(items[0].json)) {\n  npcConnections = [...items[0].json];\n}\n// Case 2: Already multiple items\nelse {\n  npcConnections = items.map(i => i.json);\n}\n\n// Weighted random selection\nconst maxInteract = npcConnections.length;\nlet interactCount = 0;\nlet prob = 0.4;\n\nfor (let i = 0; i < maxInteract; i++) {\n  if (Math.random() < prob) interactCount++;\n  prob *= 0.6;\n}\n\nif (interactCount === 0) interactCount = 1;\n\n// Fisher–Yates shuffle\nfor (let i = npcConnections.length - 1; i > 0; i--) {\n  const j = Math.floor(Math.random() * (i + 1));\n  [npcConnections[i], npcConnections[j]] = [npcConnections[j], npcConnections[i]];\n}\n\nconst selected = npcConnections.slice(\n  0,\n  Math.min(interactCount, npcConnections.length)\n);\n\nreturn selected.map(item => ({ json: item }));\n"
      },
